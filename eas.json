{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },

  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },

    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_MAPBOX_TOKEN": "${EXPO_PUBLIC_MAPBOX_TOKEN}"
      }
    },

    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_MAPBOX_TOKEN": "${EXPO_PUBLIC_MAPBOX_TOKEN}"
      }
    }
  },

  "submit": {
    "production": {}
  }
}